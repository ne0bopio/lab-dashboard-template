# Lab Dashboard Configuration
# Copy this to .env and fill in your values

# API Key — used for authenticating requests (change this!)
LAB_API_KEY=change-me-please

# Database path (default: ./data/lab.db — auto-created)
# LAB_DB_PATH=./data/lab.db

# OpenClaw home directory (default: ~/.openclaw)
# OPENCLAW_HOME=/home/youruser/.openclaw

# Workspace root for file browser (default: ~/.openclaw)
# WORKSPACE_ROOT=/home/youruser/.openclaw

# Tools directory (default: ~/.openclaw/tools)
# TOOLS_DIR=/home/youruser/.openclaw/tools

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_CHAT_ID=your_telegram_chat_id
